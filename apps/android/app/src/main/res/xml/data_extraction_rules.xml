<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) data extraction rules.
  Controls what is included in cloud and device-to-device transfers.
  Only user progress (database) and preferences are backed up.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="counterline.db" />
        <include domain="sharedpref" path="settings.preferences_pb" />
        <exclude domain="database" path="counterline.db-journal" />
        <exclude domain="database" path="counterline.db-wal" />
        <exclude domain="no_backup" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="counterline.db" />
        <include domain="sharedpref" path="settings.preferences_pb" />
        <exclude domain="database" path="counterline.db-journal" />
        <exclude domain="database" path="counterline.db-wal" />
    </device-transfer>
</data-extraction-rules>
