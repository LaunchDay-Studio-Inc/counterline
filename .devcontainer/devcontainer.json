{
  "name": "counterline",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {},
  "hostRequirements": {
    "cpus": 2,
    "memory": "8gb",
    "storage": "32gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-python.python",
        "charliermarsh.ruff",
        "timonwong.shellcheck"
      ]
    }
  },
  "postCreateCommand": "make setup"
}

